# ================================================================
#  MealBox SaaS — Client Deployment Config
#  Copy this to .env and fill in values for each client
# ================================================================

NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Security ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# ── Brand ────────────────────────────────────────────────────────
BRAND_NAME=Salad Caffe
BRAND_TAGLINE=Helping to live healthily
BRAND_COLOR=#065f46
BRAND_COLOR_LIGHT=#d1fae5
BRAND_SUPPORT_PHONE=9000000001
BRAND_LOGO_URL=

# ── Google Maps ──────────────────────────────────────────────────
GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── First Admin User (created on first deploy) ───────────────────
ADMIN_NAME=Admin
ADMIN_PHONE=9000000001
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@123

# ================================================================
#  FEATURE FLAGS
#  true = ON for this client | false or missing = OFF
# ================================================================

# ── CORE (default ON — included in all plans) ────────────────────
# FEATURE_MULTI_KITCHEN=true       # Multiple kitchen support
# FEATURE_DELIVERY_MAP=true        # Map tab for delivery boys
# FEATURE_CUSTOMER_APP=true        # Customer PWA

# ── GROWTH TIER (₹5,999/mo) ─────────────────────────────────────
FEATURE_LOYALTY_POINTS=false       # Points per delivery, redeem on renewal
FEATURE_INVOICE_PDF=false          # Auto-generate PDF invoice per order
FEATURE_ADVANCED_REPORTS=false     # Revenue, retention, churn reports
FEATURE_SALES_APP=false            # Sales team mobile app

# ── PRO TIER (₹9,999/mo) ────────────────────────────────────────
FEATURE_WHATSAPP=false             # WhatsApp order confirmations & reminders
FEATURE_SMS=false                  # SMS skip reminders & OTP
FEATURE_ONLINE_PAYMENT=false       # Razorpay online payment collection
FEATURE_API_ACCESS=false           # REST API for third-party integrations
FEATURE_CUSTOM_DOMAIN=false        # Custom domain support

# ── ADD-ONS (any tier, charged separately) ───────────────────────
FEATURE_CALORIE_TRACKING=false     # Daily calorie dashboard for customers
FEATURE_ALLERGY_ALERTS=false       # Push alerts for allergy-flagged items
FEATURE_LIVE_TRACKING=false        # Real-time delivery tracking on map
FEATURE_FEEDBACK=false             # Post-delivery rating & feedback system
FEATURE_REFERRAL=false             # Refer a friend, get discount system